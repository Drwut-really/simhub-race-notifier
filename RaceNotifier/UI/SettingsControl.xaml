<UserControl x:Class="RaceNotifier.UI.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d"
             d:DesignWidth="760">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <!-- Master on/off switch -->
            <styles:SHToggleCheckbox x:Name="PluginEnabledCheck"
                                     Content="Plugin enabled"
                                     Margin="0,0,0,8" />

            <!-- Restart banner (shown only when newly added buttons need a restart) -->
            <Border x:Name="RestartBanner" Visibility="Collapsed"
                    Background="#553311" Padding="8" Margin="0,0,0,8" CornerRadius="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="520"
                               Text="New message buttons were added. Restart SimHub to finish making them bindable." />
                    <styles:SHButtonPrimary x:Name="BannerRestartButton"
                                            Content="Restart SimHub"
                                            Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <styles:SHTabControl>
                        <styles:SHTabItem Header="Messages">
                            <StackPanel Margin="4">
                                <styles:SHInlineInfo x:Name="VariablesHelp" Margin="0,0,0,8" />
                                <styles:SHButtonPrimary x:Name="AddMessageButton"
                                                        HorizontalAlignment="Left"
                                                        Content="+ Add message" Margin="0,0,0,8" />
                                <StackPanel x:Name="MessagesContainer" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="Destinations">
                            <StackPanel Margin="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Type" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <ComboBox x:Name="DestTypeCombo" Width="160"
                                              SelectedIndex="0" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Discord" />
                                        <ComboBoxItem Content="Custom webhook" />
                                    </ComboBox>
                                    <styles:SHButtonPrimary x:Name="AddDestinationButton"
                                                            Content="+ Add destination"
                                                            Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel x:Name="DestinationsContainer" Margin="0,8,0,0" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="General">
                            <StackPanel Margin="4">
                                <styles:SHToggleCheckbox x:Name="PrefixCheck"
                                                         Content="Prefix every message with my name" />
                                <TextBlock Text="Sender name" Margin="0,8,0,2" />
                                <TextBox x:Name="SenderNameBox" Width="260" HorizontalAlignment="Left" />
                                <styles:SHSectionSeparator />
                                <styles:SHButtonPrimary x:Name="RestartButton"
                                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                                        Content="Restart SimHub" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="Help">
                            <StackPanel x:Name="HelpContainer" Margin="4" />
                        </styles:SHTabItem>
            </styles:SHTabControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
