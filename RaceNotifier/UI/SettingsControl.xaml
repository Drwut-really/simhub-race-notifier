<UserControl x:Class="RaceNotifier.UI.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d"
             d:DesignWidth="760">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8">
            <!-- Description, directly under the page title -->
            <TextBlock Text="Send preset messages to Discord or a custom webhook when you press a bound wheel button."
                       TextWrapping="Wrap" Margin="0,0,0,8" />

            <!-- Master on/off switch -->
            <styles:SHToggleCheckbox x:Name="PluginEnabledCheck"
                                     Content="Plugin enabled"
                                     Margin="0,0,0,8" />

            <!-- Restart banner (shown only when newly added buttons need a restart) -->
            <Border x:Name="RestartBanner" Visibility="Collapsed"
                    Background="#553311" Padding="8" Margin="0,0,0,8" CornerRadius="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="520"
                               Text="New message buttons were added. Restart SimHub to finish making them bindable." />
                    <styles:SHButtonPrimary x:Name="BannerRestartButton"
                                            Content="Restart SimHub"
                                            Margin="10,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <styles:SHTabControl>
                        <styles:SHTabItem Header="Messages">
                            <StackPanel Margin="4">
                                <styles:SHButtonPrimary x:Name="AddMessageButton"
                                                        HorizontalAlignment="Left"
                                                        Content="+ Add message" Margin="0,0,0,8" />
                                <StackPanel x:Name="MessagesContainer" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="Destinations">
                            <StackPanel Margin="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Type" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <ComboBox x:Name="DestTypeCombo" Width="160"
                                              SelectedIndex="0" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Discord" />
                                        <ComboBoxItem Content="Custom webhook" />
                                    </ComboBox>
                                    <styles:SHButtonPrimary x:Name="AddDestinationButton"
                                                            Content="+ Add destination"
                                                            Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.8"
                                           Text="URLs are stored locally by SimHub and are never written to the project repository." />
                                <StackPanel x:Name="DestinationsContainer" Margin="0,8,0,0" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="General">
                            <StackPanel Margin="4">
                                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,8"
                                           Text="Binding: trigger a message in either of two ways. (1) Simple bind — on the Messages tab, click the bind button on the message's row and press your wheel button. (2) Controls &amp; Events — bind the input named RaceNotifierPlugin.SendMessageN under SimHub's Controls &amp; Events menu. Either way it fires on any press type." />
                                <styles:SHSectionSeparator />
                                <styles:SHToggleCheckbox x:Name="PrefixCheck"
                                                         Content="Prefix every message with my name" />
                                <TextBlock Text="Sender name" Margin="0,8,0,2" />
                                <TextBox x:Name="SenderNameBox" Width="260" HorizontalAlignment="Left" />
                                <styles:SHSectionSeparator />
                                <TextBlock TextWrapping="Wrap" Opacity="0.8"
                                           Text="Dashboard properties: RaceNotifierPlugin.LastSendStatus, RaceNotifierPlugin.LastSendMessage. Events: RaceNotifierPlugin.MessageSent, RaceNotifierPlugin.MessageFailed (bind to sounds/LEDs in SimHub)." />
                                <styles:SHSectionSeparator />
                                <styles:SHButtonPrimary x:Name="RestartButton"
                                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                                        Content="Restart SimHub" />
                                <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Opacity="0.8"
                                           Text="Restart is occasionally needed so newly added message buttons become bindable under Controls and Events. Removing a message frees its button slot; the next new message reuses it and inherits any binding that slot already had." />
                            </StackPanel>
                        </styles:SHTabItem>
            </styles:SHTabControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
