<UserControl x:Class="RaceNotifier.UI.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d"
             d:DesignWidth="760">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <styles:SHSection Title="RACE NOTIFIER" ShowSeparator="True">
                <StackPanel>
                    <TextBlock Text="Send preset Discord messages to your team when you press a bound wheel button."
                               TextWrapping="Wrap" Margin="0,0,0,8" />

                    <styles:SHTabControl>
                        <styles:SHTabItem Header="Messages">
                            <StackPanel x:Name="MessagesContainer" Margin="4" />
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="Destinations">
                            <StackPanel Margin="4">
                                <styles:SHButtonPrimary x:Name="AddDiscordButton"
                                                        HorizontalAlignment="Left"
                                                        Content="+ Add Discord destination" />
                                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.8"
                                           Text="Webhook URLs are stored locally by SimHub and are never written to the project repository." />
                                <StackPanel x:Name="DestinationsContainer" Margin="0,8,0,0" />
                            </StackPanel>
                        </styles:SHTabItem>

                        <styles:SHTabItem Header="General">
                            <StackPanel Margin="4">
                                <styles:SHToggleCheckbox x:Name="PrefixCheck"
                                                         Content="Prefix every message with my name" />
                                <TextBlock Text="Sender name" Margin="0,8,0,2" />
                                <TextBox x:Name="SenderNameBox" Width="260" HorizontalAlignment="Left" />
                                <styles:SHSectionSeparator />
                                <TextBlock TextWrapping="Wrap" Opacity="0.8"
                                           Text="Dashboard properties: RaceNotifier.LastSendStatus, RaceNotifier.LastSendMessage. Events: MessageSent, MessageFailed (bind to sounds/LEDs in SimHub)." />
                            </StackPanel>
                        </styles:SHTabItem>
                    </styles:SHTabControl>
                </StackPanel>
            </styles:SHSection>
        </StackPanel>
    </ScrollViewer>
</UserControl>
